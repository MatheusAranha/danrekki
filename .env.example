# ── Backend (Render) ────────────────────────────────────────────────────────────
PORT=3000
MONGO_URL=mongodb://localhost:27017/danrekki
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Google OAuth — create credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend origin — set to your Vercel URL in production (e.g. https://danrekki.vercel.app)
FRONTEND_URL=http://localhost:4200

# ── Frontend (Vercel) — prefix MUST be VITE_ ────────────────────────────────────
# Full URL of the Render API (no trailing slash, no /api suffix)
VITE_API_URL=
# Same Google Client ID used on the backend
VITE_GOOGLE_CLIENT_ID=
