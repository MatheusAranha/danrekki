# ── Backend (Render) ────────────────────────────────────────────────────────────
PORT=3000
MONGO_URL=mongodb://localhost:27017/danrekki
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Google OAuth — create credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend origin — set to your Vercel URL in production (e.g. https://danrekki.vercel.app)
FRONTEND_URL=http://localhost:4200

# ── Frontend (Vite) — prefix MUST be VITE_ ─────────────────────────────────────
# Vite reads .env from the workspace root (envDir set in vite.config.ts)
# Full URL of the API in production (leave empty for local dev — proxy handles it)
VITE_API_URL=
# Must be the same value as GOOGLE_CLIENT_ID above
VITE_GOOGLE_CLIENT_ID=
