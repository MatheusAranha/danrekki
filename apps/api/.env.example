# MongoDB connection string — must point to a ReplicaSet for atomic DT transactions
MONGO_URL=mongodb://localhost:27017/danrekki?replicaSet=rs0

# JWT secret — use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=dev-secret-change-in-production

# JWT token lifetime
JWT_EXPIRES_IN=7d

# Port the API listens on
PORT=3000
